# NEXUS Configuration
# Copy this to .env and fill in your values

# Trading Mode
NEXUS_PAPER=true                    # Start with paper trading (recommended)
NEXUS_DATA_DIR=~/.nexus/data        # Data storage directory
NEXUS_LOG_LEVEL=INFO                # DEBUG for verbose output

# Analysis
NEXUS_TIMEFRAMES=15m,1h,4h,1D      # Timeframes for multi-TF analysis
NEXUS_SCAN_INTERVAL=30             # Minutes between autonomous scans
NEXUS_MIN_CONFIDENCE=0.65           # Minimum confidence to generate signal

# Risk Management
NEXUS_MAX_POSITION_PCT=0.05         # Max 5% per position
NEXUS_MAX_PORTFOLIO_RISK=0.20       # Max 20% total exposure
NEXUS_MAX_DRAWDOWN_PCT=0.15         # Stop trading at 15% drawdown
NEXUS_KELLY_FRACTION=0.5            # Half-Kelly sizing

# Exchange API Keys (optional — paper mode works without these)
CCXT_MEXC_KEY=
CCXT_MEXC_SECRET=
CCXT_BINANCE_KEY=
CCXT_BINANCE_SECRET=
CCXT_BYBIT_KEY=
CCXT_BYBIT_SECRET=

# Telegram (optional — for bot notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
